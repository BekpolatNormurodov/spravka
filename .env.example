# Single MySQL database for the whole system
DATABASE_URL="mysql://root:root@localhost:3310/spravka"
# JWT signing secret for the role apps (min 32 chars)
AUTH_SECRET="change-me-to-a-long-random-string-min-32-chars"
# Where a scanned QR lands: web-public (:5100), which serves /m/<id>. NOT web-qr (:5000) —
# that app has no /m route, and pointing here at it printed QR codes that 404.
#
# BAKED IN AT BUILD TIME. Next inlines every NEXT_PUBLIC_* during `next build`, so this must be
# right BEFORE you build. Get it wrong and the QR on every document issued from that build points
# somewhere else — and those PDFs are frozen, so it cannot be corrected afterwards.
#   dev:  http://localhost:5100
#   prod: https://qrsystem.uz
NEXT_PUBLIC_PUBLIC_URL="https://qrsystem.uz"
# Where signed maʼlumotnoma PDFs are frozen. Absolute, outside the repo, and INCLUDED IN BACKUPS:
# these are issued legal documents, not a cache. A lost file cannot be re-made — re-rendering
# produces a different file, not the one that was issued.
CERT_STORAGE_DIR="/var/lib/spravka/storage"
