# Copy to .env next to docker-compose.yml. Git-ignored.
#
#   cp .env.docker.example .env && nano .env
#
# Note DATABASE_URL is NOT here: compose builds it from MYSQL_ROOT_PASSWORD and points it at the
# `mysql` service. The root .env.example is for running on the host without Docker.

# The database lives in a named volume and is never published, so this password guards the volume
# rather than the network. Still generate it — `docker exec` is not a wall.
#   openssl rand -base64 24 | tr -d '#$/+='
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=spravka

# Signs every session cookie, shared by all four apps — a cookie set by one must verify in the
# others, so it is ONE value here, not four. In production the app refuses to start rather than
# fall back to a known default.
#   openssl rand -base64 48 | tr -d '#$'
AUTH_SECRET=

# BAKED INTO THE BUNDLE AT BUILD TIME by `next build` — compose passes it as a build arg, so
# changing it later needs `docker compose up -d --build`, not a restart.
#
# This is the URL printed into every QR. Wrong value = every document issued from that build has a
# dead QR, permanently: the PDFs are frozen and cannot be reissued.
NEXT_PUBLIC_PUBLIC_URL=https://qrsystem.uz

# Only for the one-off seed (deploy/README.md). The demo password is published in this repository
# and `rahbar` is the account that signs, so production refuses to seed without this.
#   openssl rand -base64 18
SEED_PASSWORD=
