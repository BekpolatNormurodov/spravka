generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Existing QR system (moved verbatim from qrcode-pro) ───────────────────
enum QrType {
  URL
  TEXT
  HTML
  FILE
  IMAGE
}

model QrCode {
  id         String   @id @db.VarChar(32)
  name       String   @db.VarChar(120)
  type       QrType   @default(URL)
  content    String?  @db.Text
  fileUrl    String?  @db.VarChar(500)
  fileName   String?  @db.VarChar(255)
  fgColor    String   @default("#0f172a") @db.VarChar(9)
  bgColor    String   @default("#ffffff") @db.VarChar(9)
  size       Int      @default(256)
  level      String   @default("M") @db.VarChar(1)
  qrImageUrl String?  @db.VarChar(500)
  scans      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([type])
}

// ─── Ma'lumotnoma system ───────────────────────────────────────────────────
enum Role {
  YURIST
  ADMIN
  RAHBAR
}

enum CertStatus {
  DRAFT
  ADMIN_REVIEW
  DIRECTOR_REVIEW
  SIGNED
}

/// Which document a Certificate row is. Everything issued before this field existed is a maʼlumotnoma.
enum DocType {
  MALUMOTNOMA
  ARIZA
}

enum WfAction {
  SUBMIT
  APPROVE
  RETURN
  SIGN
  DELETE
  RESTORE
}

model User {
  id            String   @id @default(cuid())
  fullName      String
  login         String   @unique
  passwordHash  String
  plainPassword String?
  role          Role
  position      String?
  phone         String?
  email         String?
  avatarPath    String?
  firmId        String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdCerts  Certificate[]   @relation("CertCreatedBy")
  signedCerts   Certificate[]   @relation("CertSignedBy")
  events        WorkflowEvent[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Firm {
  id               String   @id @default(cuid())
  /// Body-text form of the name — the source documents end it 'МЧЖ'.
  name             String
  /// Letterhead + signature form. The firms' own blanks end it 'MCHJ' while the body says
  /// 'МЧЖ', and it is not consistent between firms, so it is stored rather than derived.
  letterheadName   String?
  shortName        String?
  stir             String?
  oked             String?
  /// Short form printed in the signature block, e.g. 'А.А.Бойназаров'.
  directorName     String
  /// Full name as registered, e.g. 'BOYNAZAROV AKRAM ANVAROVICH'.
  directorFullName String?
  directorPosition String   @default("Ижрочи директори")
  /// Bosh buxgalter. Never printed on the maʼlumotnoma — firm reference data only.
  accountantName   String?
  /// Whoever prepared the document (the 'Ижрочи' line). Optional: the line is omitted
  /// when the firm has not named one.
  executorName     String?
  executorPhone    String?
  phone            String?
  email            String?
  website          String?
  region           String?
  address          String?
  bankName         String?
  bankAccount      String?
  mfo              String?
  logoPath         String?
  sealPath         String?
  signaturePath    String?
  isActive         Boolean  @default(true)
  certificates     Certificate[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Certificate {
  id               String     @id @db.VarChar(32)
  number           String     @unique
  seq              Int
  issueDate        DateTime
  firm             Firm       @relation(fields: [firmId], references: [id])
  firmId           String
  status           CertStatus @default(DRAFT)

  personFullName   String
  /// Nullable because an ariza debtor is identified by PINFL, not a passport. Validation requires it
  /// only for a MALUMOTNOMA. Every existing row already has a value.
  personPassport   String?
  passportIssuedBy String?
  passportIssuedAt DateTime?

  /// A maʼlumotnoma covers one or more contracts — the real blanks routinely list two.
  contracts        CertContract[]
  contractType     String     @default("«Микроқарз» универсал шартномаси")
  /// Total across every contract listed above — the «умумий ... сўм» figure.
  loanAmount       Decimal    @db.Decimal(18, 2)
  asOfDate         DateTime
  /// The «... ҳолатида» phrase exactly as the yurist wrote it, e.g. '2026 йил 19 июль'.
  ///
  /// The document prints this when set and derives it from `asOfDate` when not, so nothing already
  /// issued changes. It exists because the phrase is Uzbek prose rather than a rendered date, and
  /// the person writing the document should be able to say it their way.
  ///
  /// `asOfDate` stays the machine-readable value and is kept in step: the phrase is re-parsed on
  /// every edit and the date follows whenever it can be read. When it cannot, the date keeps its
  /// last good value and the two disagree — so read `asOfText` for what the paper says, and
  /// `asOfDate` only for sorting, never as evidence of what was printed.
  asOfText         String?

  /// The second addressee — the «Маълумот учун:» line under the person the maʼlumotnoma is
  /// written to, e.g. '«KAPITAL SUGʻURTA» Акциядорлик жамиятига'.
  ///
  /// Null means the document has no such line at all, which is the ordinary case and what every
  /// row issued before this field existed says. Stored with its own case ending («…жамиятига»,
  /// «…МЧЖга», «…банкига») rather than having one appended: the suffix depends on the word it
  /// attaches to, and guessing it wrong prints a grammatical error on a legal document.
  infoRecipient    String?

  /// Which document this row is. Defaulted so every pre-existing row is a maʼlumotnoma.
  docType          DocType    @default(MALUMOTNOMA)

  // ── «Savdo-sanoat palatasiga ariza» fields — null on a maʼlumotnoma ─────────────────────────
  /// Full court addressee, e.g. «Fuqarolik ishlari boʻyicha Uchtepa tumanlararo sudiga».
  courtName        String?
  /// Yearly rate as typed ('54'); printed with a '%'.
  interestRate     String?
  /// Debtor address and phone, snapshotted like the other person* fields.
  personAddress    String?
  personPhone      String?
  /// Qarzdorlik taqsimoti — stored with tiyin. `debtTotal` is auto-summed in the editor but stored
  /// (a red field on the blank) and overridable.
  debtPrincipal        Decimal? @db.Decimal(18, 2)
  debtTermInterest     Decimal? @db.Decimal(18, 2)
  debtOverduePrincipal Decimal? @db.Decimal(18, 2)
  debtOverdueInterest  Decimal? @db.Decimal(18, 2)
  debtTotal            Decimal? @db.Decimal(18, 2)
  /// The palata's signer and executor for this ariza. Defaults live in the UI, not here.
  chamberSignerPosition String?
  chamberSignerName     String?
  chamberExecutorName   String?
  chamberExecutorPhone  String?

  bodyText         String?    @db.Text
  /// Path (relative to CERT_STORAGE_DIR) of the document frozen at SIGN time. This file is the
  /// issued maʼlumotnoma — the on-screen view is a re-render of it, not the other way round.
  pdfPath          String?
  /// Digest of the bytes at pdfPath. Catches a file that was corrupted or swapped underneath the
  /// row, which nothing else would notice, and is what an E-IMZO signature will be checked
  /// against once that becomes possible.
  pdfSha256        String?

  /// Frozen copy of the firm's rekvizitlar taken at SIGN time. Once signed, the document
  /// renders from this — editing the Firm later must never alter an issued maʼlumotnoma.
  /// Null while the ariza is still editable (then it renders from the live Firm).
  firmSnapshot     Json?

  /// The rahbar's E-IMZO signature, when one was made. Absent means the document rests on the
  /// system's own record and the QR alone — which is the case for everything issued so far.
  signature        CertSignature?

  signedBy         User?      @relation("CertSignedBy", fields: [signedById], references: [id])
  signedById       String?
  signedAt         DateTime?
  scans            Int        @default(0)

  deletedAt        DateTime?
  deletedById      String?
  deletedReason    String?    @db.Text

  // Link to the reusable client record. The person* fields above stay as an immutable
  // snapshot of what this document says — editing the Client must never alter an
  // already-issued maʼlumotnoma.
  client           Client?    @relation(fields: [clientId], references: [id])
  clientId         String?
  personPinfl      String?    @db.VarChar(14)

  createdBy        User       @relation("CertCreatedBy", fields: [createdById], references: [id])
  createdById      String
  events           WorkflowEvent[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([status])
  @@index([firmId])
  @@index([clientId])
}

/// The rahbar's E-IMZO signature over the frozen PDF.
///
/// `verified` is the whole story of this table. Producing a signature needs nothing but the
/// rahbar's key; *checking* one needs E-IMZO-SERVER and a NIC contract, which we do not have.
/// So the row is evidence, not proof: it is a real PKCS#7 made by a real key on the rahbar's own
/// machine, and a third party with E-IMZO-SERVER can verify it — we cannot, yet. Until we can,
/// nothing in the UI may call the document «tasdiqlangan» on the strength of this row.
///
/// Nothing here is trusted input. `signerInfo` is whatever the browser reported and could say
/// anything; it exists so a human can see which key was used, never to decide anything.
model CertSignature {
  id            String      @id @default(cuid())
  certificate   Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  certificateId String      @unique
  /// base64 PKCS#7/CMS with the document attached.
  pkcs7         String      @db.LongText
  /// Digest of the PDF that was signed. Must equal Certificate.pdfSha256 — the server checks
  /// this on the way in, so a signature can never drift from the bytes it covers.
  pdfSha256     String
  /// Set only once an E-IMZO-SERVER has actually checked it. Never set by the client.
  verified      Boolean     @default(false)
  verifiedAt    DateTime?
  /// Untrusted, informational: the key's alias/name as the client reported it.
  signerInfo    Json?
  createdAt     DateTime    @default(now())
}

/// A rendered-but-uncommitted document awaiting its signature.
///
/// The rahbar signs bytes, so the server must know exactly which bytes it handed out: without
/// this row, a client could sign anything at all and we would store it against the document.
/// Short-lived by design — one signing attempt.
model SignChallenge {
  id            String   @id @default(cuid())
  certificateId String
  /// The rahbar who asked. Only they may complete it.
  userId        String
  /// Digest of the PDF handed to the client; the returned PKCS#7 must cover exactly this.
  pdfSha256     String
  /// The rekvizitlar the PDF was rendered from, carried here rather than re-read at commit: an
  /// admin editing the Firm in the seconds between the two would otherwise leave the stored
  /// snapshot describing a document that was never rendered.
  firmSnapshot  Json
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([certificateId])
  @@index([expiresAt])
}

/// One «Микроқарз» contract a maʼlumotnoma covers, printed in `order`. Kept as rows rather
/// than a Json column so the arizalar search can still match a contract number.
model CertContract {
  id            String      @id @default(cuid())
  certificate   Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  certificateId String
  number        String
  date          DateTime
  order         Int         @default(0)
  createdAt     DateTime    @default(now())

  @@index([certificateId])
  @@index([number])
}

/// Mijoz (jismoniy shaxs) — identified by PINFL (14 digits). Looked up by the yurist so
/// repeat clients autofill. The Certificate keeps its own snapshot of the person fields so
/// editing a client never rewrites an already-issued document.
model Client {
  id               String        @id @default(cuid())
  pinfl            String        @unique @db.VarChar(14)
  fullName         String
  /// Nullable: a client first seen through an ariza has no passport yet — it is filled the day they
  /// get a maʼlumotnoma. Every existing client already has one.
  passport         String?
  passportIssuedBy String?
  passportIssuedAt DateTime?
  birthDate        DateTime?
  phone            String?
  address          String?
  certificates     Certificate[]
  createdById      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([fullName])
}

model WorkflowEvent {
  id            String      @id @default(cuid())
  certificate   Certificate @relation(fields: [certificateId], references: [id])
  certificateId String
  actor         User        @relation(fields: [actorId], references: [id])
  actorId       String
  action        WfAction
  fromStatus    CertStatus
  toStatus      CertStatus
  /// What the actor wrote when they moved the ariza — the admin's message to the rahbar, the
  /// reason for a return. Shown to all three roles; never public.
  note          String?     @db.Text
  attachments   EventAttachment[]
  createdAt     DateTime    @default(now())

  @@index([certificateId])
}

/// A file the actor attached to a workflow step — a screenshot, a scan, a spreadsheet the
/// rahbar wants before approving. Supporting evidence for the decision, NOT part of the
/// issued maʼlumotnoma: it is never served from the public page.
model EventAttachment {
  id         String        @id @default(cuid())
  event      WorkflowEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId    String
  fileName   String
  /// Path relative to CERT_STORAGE_DIR.
  path       String
  mime       String
  size       Int
  sha256     String
  createdAt  DateTime      @default(now())

  @@index([eventId])
}

model Counter {
  id    String @id
  value Int    @default(0)
}
