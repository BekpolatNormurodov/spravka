# ============================================================================
# DATABASE — the one shared DB for the whole system.
# The schema lives in packages/shared/prisma/schema.prisma; this app does not
# own a schema and never runs its own migrations.
# ============================================================================
DATABASE_URL="mysql://root:your_mysql_password@localhost:3306/spravka"

# ============================================================================
# WEB LOGIN — web-qr keeps its own env-based admin login. It is separate from
# the YURIST/ADMIN/RAHBAR users in the User table, and separate from the MySQL
# credentials above.
# ============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password_here

# JWT signing secret (long random string, minimum 32 characters)
AUTH_SECRET=your_very_long_random_secret_key_here_min_32_chars

# Base URL baked into the QR links. Put the real domain here in production.
NEXT_PUBLIC_APP_URL=http://localhost:5000
